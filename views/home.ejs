<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vertex</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <!-- Animated Background -->
  <div class="animated-bg"></div>

  <nav class="navbar navbar-expand-lg fixed-top">
    <div class="container">
      <a class="navbar-brand" href="#">VERTEX</a>
      <button class="navbar-toggler navbar-dark" type="button" data-bs-toggle="collapse"
        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
        aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about">About</a>
          </li>

          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              Bookings
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/view-slots">View Booked Slots</a></li>
              <li>
                <hr class="dropdown-divider">
              </li>
              <li><a class="dropdown-item" href="#">Support</a></li>
            </ul>
          </li>
        </ul>
        <a href="/book" class="btn btn-outline-success rounded-pill px-4">
          Book Slot
        </a>

      </div>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <div class="hero-section">
    <div class="container">
      <h2 class="hero-subtitle">WELCOME TO THE FUTURE</h2>
      <h1 class="hero-title">PRADEEP KASTURI</h1>
      <p class="lead text-white-50 mt-3 mb-5" style="opacity:0; animation: fadeInUp 1s ease forwards 0.9s;">
        Premium Architecture & Design Solutions
      </p>
      <div>
        <a href="/book" class="btn btn-glow">
          Book Appointment
        </a>
      </div>
    </div>
  </div>

  <!-- SUPERPROFILE LINKS SECTION -->
  <div class="container my-5" style="max-width: 800px;">
    <!-- Profile Info / Avatar (Optional for SuperProfile vibe, though we have a Hero above) -->
    <div class="text-center mb-4 mt-5">
      <img src="https://ui-avatars.com/api/?name=Pradeep+Kasturi&background=00ff88&color=000&size=120" class="rounded-circle mb-3 border border-2 border-success" alt="Profile Avatar" style="box-shadow: 0 0 20px rgba(0,255,136,0.3);">
      <h3 class="text-white">@pradeepkasturi</h3>
    </div>

    <!-- Quick Links -->
    <div class="d-grid gap-3 mb-5">
      <a href="#" class="btn superprofile-link">
        <i class="bi bi-youtube me-2"></i> Watch my latest YouTube Video
      </a>
      <a href="#" class="btn superprofile-link">
        <i class="bi bi-instagram me-2"></i> Follow me on Instagram
      </a>
      <a href="/book" class="btn superprofile-link spotlight">
        <i class="bi bi-calendar-check me-2"></i> Book a 1:1 Consultation
      </a>
    </div>

    <!-- DIGITAL PRODUCTS STOREFRONT -->
    <h4 class="text-center mb-4 mt-5 text-white" style="letter-spacing: 2px;">DIGITAL STORE</h4>
    <div class="row g-4 mb-5">
      <!-- Product 1 -->
      <div class="col-md-6">
        <div class="card product-card h-100 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Modern Architecture Masterclass" style="height: 200px; object-fit: cover; opacity: 0.8;">
          <div class="card-body text-center p-4">
            <h5 class="card-title text-white">Modern Architecture Masterclass</h5>
            <p class="text-white-50 small mb-4">Learn the secrets of designing premium spaces.</p>
            <div class="d-flex justify-content-between align-items-center">
              <span class="fs-5 fw-bold" style="color: var(--primary-color)">$99.00</span>
              <a href="#" class="btn btn-outline-success rounded-pill btn-sm px-4">Buy Now</a>
            </div>
          </div>
        </div>
      </div>
      <!-- Product 2 -->
      <div class="col-md-6">
        <div class="card product-card h-100 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Interior Layout Templates" style="height: 200px; object-fit: cover; opacity: 0.8;">
          <div class="card-body text-center p-4">
            <h5 class="card-title text-white">Interior Layout Templates</h5>
            <p class="text-white-50 small mb-4">50+ ready-to-use AutoCAD floor plan templates.</p>
            <div class="d-flex justify-content-between align-items-center">
              <span class="fs-5 fw-bold" style="color: var(--primary-color)">$29.00</span>
              <a href="#" class="btn btn-outline-success rounded-pill btn-sm px-4">Buy Now</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- NEWSLETTER / LEAD GENERATION -->
    <div class="card newsletter-card p-4 p-md-5 my-5 text-center">
      <div class="card-body">
        <h4 class="text-white mb-3">Join My Inner Circle</h4>
        <p class="text-white-50 mb-4">Subscribe to get weekly architecture tips and exclusive design freebies.</p>
        <form class="d-flex flex-column flex-md-row gap-2 justify-content-center">
          <input type="email" class="form-control bg-dark text-white border-secondary text-center text-md-start" placeholder="Your best email address" required style="max-width: 400px; margin: 0 auto;">
          <button type="submit" class="btn btn-glow mt-3 mt-md-0" style="padding: 10px 25px; font-size: 1rem;">Subscribe</button>
        </form>
      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
</body>

</html>