<!-- Mock Payment Page -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Payment - Vertex</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css" />
    <style>
        .payment-card {
            background: linear-gradient(145deg, rgba(20,20,24,0.9), rgba(10,10,12,0.95));
            border: 1px solid rgba(0, 255, 136, 0.3);
            border-radius: 20px;
            padding: 3rem;
            box-shadow: 0 0 30px rgba(0,255,136,0.1);
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <!-- Animated Background -->
    <div class="animated-bg"></div>
    
    <div class="container" style="max-width: 600px;">
        <div class="payment-card">
            <h2 class="text-white text-center mb-1">Checkout</h2>
            <p class="text-center" style="color: var(--primary-color);" id="serviceNameDisplay">Loading Service...</p>
            <p class="text-white-50 text-center mb-5">Please complete your payment to finalize your booking.</p>
            
            <div class="d-flex justify-content-between mb-4 pb-3 border-bottom border-secondary">
                <span class="text-white fs-5">Total Amount</span>
                <span class="fs-3 fw-bold" style="color: var(--primary-color)" id="priceDisplay">$--</span>
            </div>

            <!-- Realistic Credit Card Form -->
            <form id="paymentForm">
                <div class="mb-3">
                    <label class="form-label text-white-50">Cardholder Name</label>
                    <input type="text" class="form-control bg-dark border-secondary text-white" required placeholder="John Doe">
                </div>
                <div class="mb-3">
                    <label class="form-label text-white-50">Card Number</label>
                    <input type="text" class="form-control bg-dark border-secondary text-white" required placeholder="0000 0000 0000 0000" maxlength="19">
                </div>
                <div class="row mb-4">
                    <div class="col-6">
                        <label class="form-label text-white-50">Expiry Date</label>
                        <input type="text" class="form-control bg-dark border-secondary text-white" required placeholder="MM/YY" maxlength="5">
                    </div>
                    <div class="col-6">
                        <label class="form-label text-white-50">CVV</label>
                        <input type="password" class="form-control bg-dark border-secondary text-white" required placeholder="123" maxlength="4">
                    </div>
                </div>

                <button type="submit" id="payBtn" class="btn btn-glow w-100 py-3" style="font-size: 1.2rem;">
                    Pay Now <span id="btnPrice"></span>
                </button>
            </form>
            
            <a href="/" class="btn btn-outline-secondary w-100 py-3 mt-3">Cancel</a>
        </div>
    </div>

    <!-- Processing Overlay / Simulation -->
    <div id="processingOverlay" class="d-none" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 9999; display: flex; align-items: center; justify-content: center; flex-direction: column;">
        <div class="spinner-border text-success" role="status" style="width: 3rem; height: 3rem;"></div>
        <h4 class="text-white mt-3 mt-4">Processing Payment...</h4>
        <p class="text-white-50">Please do not close this window</p>
    </div>

    <script>
        // 1. Parse URL Parameters
        const urlParams = new URLSearchParams(window.location.search);
        const price = urlParams.get('price') || '150';
        const service = urlParams.get('service') || '1:1 Consultation';

        // 2. Set UI Elements
        document.getElementById('priceDisplay').textContent = "$" + price + ".00";
        document.getElementById('serviceNameDisplay').textContent = service;
        document.getElementById('btnPrice').textContent = "- $" + price + ".00";

        // 3. Handle Mock Payment Submission
        document.getElementById('paymentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Show processing overlay
            document.getElementById('processingOverlay').classList.remove('d-none');
            
            // Simulate network delay / bank verification
            setTimeout(() => {
                alert("Payment Successful! Thank you for booking with Vertex.");
                window.location.href = "/view-slots";
            }, 2500); // 2.5 seconds fake processing time
        });
    </script>
</body>
</html>
